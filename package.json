{
  "name": "@nonos/nox-dashboard",
  "version": "0.1.2",
  "description": "Local-first staking dashboard for NOX. Run it on your own machine, connect your own RPC and wallet, and stake without trusting a website.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/NON-OS/NOXDashboard",
  "repository": {
    "type": "git",
    "url": "https://github.com/NON-OS/NOXDashboard.git"
  },
  "bugs": "https://github.com/NON-OS/NOXDashboard/issues",
  "keywords": [
    "nox",
    "nonos",
    "staking",
    "dashboard",
    "ethereum",
    "local-first"
  ],
  "type": "module",
  "bin": {
    "nox-dashboard": "bin/nox-dashboard.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc -p . --noEmit",
    "start": "node bin/nox-dashboard.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@nonos/nox-staking-sdk": "^0.2.0",
    "@walletconnect/ethereum-provider": "2.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.0",
    "zustand": "^5.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.6"
  }
}
